# =============================================================================
# .env 样例
# -----------------------------------------------------------------------------
# 此 env 为 bootstrap 阶段（连 Nacos 之前）必须就位的最小环境变量集合
# 业务字段由 Nacos 配置中心注入
#
# 用法：
#   cp .env.example .env
#   按需修改相关变量
# =============================================================================

# Nacos 接入
NACOS_SERVER_ADDR=localhost:8848
NACOS_USERNAME=nacos
NACOS_PASSWORD=nacos

# Profile
PROFILE=dev

# 以下字段都有合理默认，注释即用默认
# 服务监听
# PORT=9700

# Nacos 命名空间 / 分组（默认 public 命名空间 + DEFAULT_GROUP）
# NACOS_NAMESPACE_ID=public
# NACOS_GROUP=DEFAULT_GROUP

# 注册到 Nacos 时的本机 IP（可选）
# 留空时由 src/nacos/registry.ts 按 inetutils 偏好自动选择，容器 / 多网卡场景下显式指定更稳
# NACOS_REGISTER_IP=127.0.0.1
